# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to GitHub.

TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — default is 30
SCAN_INTERVAL_MINUTES=30

# Autotrading: Fernet key for encrypting user OKX API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTOTRADE_ENC_KEY=
# Optional overrides
# AUTOTRADE_ENABLED=1
# AUTOTRADE_LEVERAGE=10
# AUTOTRADE_BALANCE_THRESHOLD=100
# AUTOTRADE_CONTACT=@sanja_tusagang
# OKX_TRADE_BASE_URL=https://my.okx.com
